# TimescaleDB Configuration
# Copy this file to .env and edit as needed

# Database connection settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=goflow2

# Admin credentials (for initial setup)
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=password

# Application credentials (for GoFlow2)
APP_USER=goflow2
APP_PASSWORD=goflow2password
APP_SCHEMA=goflow2

# Docker Compose settings
TIMESCALEDB_IMAGE=timescale/timescaledb:latest-pg16
TIMESCALEDB_TELEMETRY=off
TIMESCALEDB_MAX_CONNECTIONS=200
TIMESCALEDB_SHARED_BUFFERS=256MB

# Optional: pgAdmin settings
PGADMIN_IMAGE=dpage/pgadmin4:latest
PGADMIN_EMAIL=admin@goflow2.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=8080

# Connection string for GoFlow2 (auto-generated)
# GOFLOW2_DB_CONN=postgres://${APP_USER}:${APP_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}